# ── Telegram ────────────────────────────────────────────────────────────────
# Токен бота от @BotFather.
BOT_TOKEN=your_bot_token_here

# Telegram user id администратора: только ему разрешена команда /reload.
# Узнать свой id можно у @userinfobot. Пусто — /reload недоступна никому.
ADMIN_TG_ID=123456789

# ── База данных ───────────────────────────────────────────────────────────────
# В docker compose DATABASE_URL подставляется автоматически из POSTGRES_* ниже.
DATABASE_URL=postgres://consultant:consultant@localhost:5432/consultant?sslmode=disable

# ── LLM ───────────────────────────────────────────────────────────────────────
# Какой провайдер использовать: gigachat | yandexgpt
LLM_PROVIDER=gigachat

# --- GigaChat (нужно при LLM_PROVIDER=gigachat) ---
# Authorization Key из личного кабинета developers.sber.ru — base64(ClientID:ClientSecret).
# НЕ коммить реальное значение.
GIGACHAT_AUTH_KEY=your_base64_authorization_key_here
# Scope доступа. Для физлица (freemium) — GIGACHAT_API_PERS.
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель GigaChat.
GIGACHAT_MODEL=GigaChat-2
# Путь к корневому сертификату Минцифры (скачивается `make cert`).
GIGACHAT_CERT_PATH=certs/russian_trusted_root_ca.cer
# Крайний фолбэк для локального демо, если сертификат недоступен: true отключает
# проверку TLS-цепочки GigaChat. НИКОГДА не включайте в проде.
GIGACHAT_INSECURE_SKIP_VERIFY=false

# --- YandexGPT (нужно при LLM_PROVIDER=yandexgpt) ---
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here
# Модель. lite дешевле и быстрее, для FAQ-консультанта достаточно.
YANDEX_MODEL=yandexgpt-lite

# ── Прочее ────────────────────────────────────────────────────────────────────
# Путь к файлу базы знаний.
KNOWLEDGE_PATH=knowledge/faq.md

# local -> slog TextHandler на уровне Debug, любое другое значение -> JSONHandler на Info
APP_ENV=local

# Креды Postgres для docker compose
POSTGRES_USER=consultant
POSTGRES_PASSWORD=consultant
POSTGRES_DB=consultant
POSTGRES_PORT=5432
